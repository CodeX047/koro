# --- Database (packages/database) ---
# Postgres / Neon connection string used by Drizzle.
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# --- Better Auth (packages/auth) ---
# Random secret used to sign sessions. Generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=

# The canonical URL of your app (used by Better Auth for redirects & CSRF).
BETTER_AUTH_URL=http://localhost:3000

# Comma-separated list of additional trusted cross-origins (e.g. a staging URL or ngrok tunnel).
# Leave empty in production unless you have a specific cross-origin use-case.
BETTER_AUTH_TRUSTED_ORIGINS=

# --- GitHub OAuth (Better Auth social login) ---
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# --- GitHub App (webhook processing & repo access) ---
GITHUB_APP_ID=
# Paste the PEM private key with literal \n between lines (no newlines in the value).
GITHUB_APP_PRIVATE_KEY=
# Must be a non-empty secret — used to verify webhook signatures.
GITHUB_WEBHOOK_SECRET=
# Slug of the GitHub App (e.g. "koro-pr"). Used to build the install URL.
GITHUB_APP_NAME=koro-pr
# Optional: override the GitHub App install link.
NEXT_PUBLIC_GITHUB_APP_LINK=

# --- AI (packages/ai) ---
OPENROUTER_API_KEY=

# --- Pinecone (vector search) ---
PINECONE_API_KEY=
PINECONE_INDEX=

# --- Web app (apps/web) ---
# URL the browser uses to reach the API's tRPC endpoint (note the /api/trpc suffix).
NEXT_PUBLIC_API_URL=http://localhost:3000/api/trpc

# The canonical app URL used by the auth client.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Optional: public URL of the frontend (used in GitHub OAuth callbacks).
FRONTEND_URL=http://localhost:3000

# --- Local dev tunnelling (optional) ---
# Comma-separated list of dev tunnel origins to allow (e.g. ngrok).
# Leave empty in production.
ALLOWED_DEV_ORIGINS=

# --- Dodo Payments (packages/billing) ---
DODO_PAYMENTS_API_KEY=
DODO_PAYMENTS_WEBHOOK_SECRET=
DODO_PAYMENTS_ENVIRONMENT=test
