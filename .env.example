# ---------------------------------------------------------------------------
# Koro — environment variables
#
# Copy this file to `.env` and fill in real values:
#   cp .env.example .env
#
# The root scripts load this file via dotenv-cli (`dotenv -- turbo ...`), so a
# single root `.env` feeds every workspace. Each app/package validates the
# variables it needs at startup (see their `env.ts` / `env.js`).
# ---------------------------------------------------------------------------

# --- Database (packages/database) ---
# Postgres / Neon connection string used by Drizzle.
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# --- Auth (packages/services) ---
# Secret used to sign/verify JWT auth tokens. Use a long random value, e.g.
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=replace-with-a-long-random-secret

# --- Web app (apps/web) ---
# URL the browser uses to reach the API's tRPC endpoint (note the /api/trpc suffix —
# the web client uses this value directly as the tRPC link URL).
NEXT_PUBLIC_API_URL=http://localhost:3000/api/trpc

# Optional: origin of the web app, if you wire CORS/redirects to it.
FRONTEND_URL=http://localhost:3000

# Optional: Clerk authentication (only if you enable Clerk in the web app).
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/
